{
  "expo": {
    "name": "Vila Nova Coletas",
    "slug": "vilanova-agro-app-react",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B6B4A"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B6B4A"
      },
      "package": "br.com.vilanova.agroapp",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://api.vilanova-agro.com.br"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "O app precisa de acesso para selecionar fotos de evidência.",
          "cameraPermission": "O app precisa de acesso à câmera para tirar fotos de evidência."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysPermission": "O app precisa de acesso à localização para registrar o ponto de coleta.",
          "locationWhenInUsePermission": "O app precisa de acesso à localização para registrar o ponto de coleta."
        }
      ]
    ],
    "scheme": "vilanovacoletas",
    "extra": {
      "router": {
        "origin": "https://api.vilanova-agro.com.br"
      },
      "eas": {
        "projectId": "05e165d3-760d-4fb1-969f-5b4d783538eb"
      }
    },
    "owner": "vinixdev00"
  }
}
